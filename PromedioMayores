lista1 = []
lista2 = []
suma=0
n=int(input("Ingrese el num"))
while n!=0:
    lista1.append(n)
    n=int(input("Ingrese el num"))

print(lista1)

for i in range(len(lista1)):
    suma+=lista1[i]

    promedio=suma/len(lista1)

for i in range(len(lista1)):
    if lista1[i]>promedio:
        lista2.append(lista1[i])

print(lista2)